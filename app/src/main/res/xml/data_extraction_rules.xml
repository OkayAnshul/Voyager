<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules (Android 12+ / API 31+).

   The SQLCipher database is excluded from BOTH cloud backup and device-transfer:
   its encryption key is Keystore-derived and device-bound, so a restored encrypted
   blob can never be opened on the destination device. See backup_rules.xml.
   Cross-device migration is via Voyager's own `.voyager` encrypted export.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="voyager_database" />
        <exclude domain="database" path="voyager_database-wal" />
        <exclude domain="database" path="voyager_database-shm" />
        <exclude domain="database" path="voyager_database-journal" />
        <exclude domain="sharedpref" path="voyager_db_keys.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="voyager_database" />
        <exclude domain="database" path="voyager_database-wal" />
        <exclude domain="database" path="voyager_database-shm" />
        <exclude domain="database" path="voyager_database-journal" />
        <exclude domain="sharedpref" path="voyager_db_keys.xml" />
    </device-transfer>
</data-extraction-rules>
