<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto-backup rules (devices < API 31).

   The SQLCipher database is DELIBERATELY excluded. Its encryption key is derived
   from the Android Keystore, which is device-bound and NOT backed up. Restoring the
   encrypted blob onto a new device would yield a DB that can never be opened — and
   the restore would overwrite the fresh install's empty DB with an unreadable one.
   Migration between devices happens through Voyager's own encrypted `.voyager` export.
-->
<full-backup-content>
    <exclude domain="database" path="voyager_database" />
    <exclude domain="database" path="voyager_database-wal" />
    <exclude domain="database" path="voyager_database-shm" />
    <exclude domain="database" path="voyager_database-journal" />
    <exclude domain="sharedpref" path="voyager_db_keys.xml" />
</full-backup-content>
