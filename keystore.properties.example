# Copy this file to keystore.properties and fill in your release signing details.
# keystore.properties is gitignored — never commit your actual signing credentials.
#
# To generate a release keystore:
#   keytool -genkey -v -keystore voyager-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias voyager
#
# Store the .jks file OUTSIDE this repo (e.g., ~/keys/) and back it up securely.
# Losing this keystore means you can never publish updates to the same Play Store listing.

storeFile=/absolute/path/to/voyager-release.jks
storePassword=your-store-password
keyAlias=voyager
keyPassword=your-key-password
